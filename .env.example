# ─── Your server's public URL ────────────────────────────────────────────────
# Instagram's API fetches images from a public HTTPS URL — localhost won't work.
#
# OPTION A — Local tunnel with ngrok (free, no deploy needed)
#   1. Install ngrok: https://ngrok.com/download  (or: brew install ngrok)
#   2. In a separate terminal: npx ngrok http 8787
#   3. Copy the "Forwarding" HTTPS URL (e.g. https://abc123.ngrok-free.app)
#   4. Paste it below and restart pnpm dev
#   Note: free-plan URL changes every restart. Use a paid static domain to avoid this.
#
# OPTION B — Deployed server
#   Set this to your production domain, e.g. https://yourapp.com
SERVER_PUBLIC_URL=https://your-ngrok-url.ngrok-free.app

# ─── Instagram Graph API ─────────────────────────────────────────────────────
# Requirements:
#   • Your Instagram account must be Business or Creator type
#   • It must be connected to a Facebook Page
#   • Your Meta App needs the instagram_content_publish permission approved
#
# How to get IG_USER_ID:
#   1. Create a Meta App at https://developers.facebook.com
#   2. Add Instagram Graph API product
#   3. GET https://graph.facebook.com/v19.0/me/accounts?access_token=<USER_TOKEN>
#      → find your Page → copy its access_token  (use this for IG_ACCESS_TOKEN)
#   4. GET https://graph.facebook.com/v19.0/<PAGE_ID>?fields=instagram_business_account&access_token=<TOKEN>
#      → instagram_business_account.id  is your IG_USER_ID
#
# Token tip: exchange a short-lived User Token for a 60-day Long-Lived Token:
#   GET https://graph.facebook.com/v19.0/oauth/access_token
#       ?grant_type=fb_exchange_token
#       &client_id=<APP_ID>
#       &client_secret=<APP_SECRET>
#       &fb_exchange_token=<SHORT_TOKEN>
IG_USER_ID=your-ig-business-account-id
IG_ACCESS_TOKEN=your-long-lived-page-access-token
